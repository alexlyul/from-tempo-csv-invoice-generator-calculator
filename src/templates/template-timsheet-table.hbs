<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>CSV Report</title>
    <style>
        html, body {
            -webkit-print-color-adjust: exact;
            print-color-adjust: exact;
        }

        .table {
            border-collapse: collapse;
            width: 100%;
        }
        .table th, .table td {
            border-right: 1px solid #dee2e6;
        }
        .table th:last-child, .table td:last-child {
            border-right: none;
        }

        .table-striped tbody tr:nth-of-type(odd) td,
        .table-striped tbody tr:nth-child(odd) td {
            background-color: #e4f9ff;
        }

        .table-striped tbody td {
            padding-top: 5px;
            padding-bottom: 5px;
        }
    </style>
</head>
<body>
<table
        class="table table-striped"
        style="width: 2800px; font-size: 14px"
>
    <caption style="font-size: 16px; font-weight: bold; text-align: center;">
        {{startDate}} - {{endDate}}
    </caption>
    <thead>
    <tr>
        {{#each tableHeaderRow}}
            <th scope="col" style="font-size: 12px;">{{this}}</th>
        {{/each}}
    </tr>
    </thead>
    <tbody>
    {{#each tableBodyRows}}
        <tr>
        {{#each this}}
            <td>{{this}}</td>
        {{/each}}
        </tr>
    {{/each}}
    </tbody>
</table>
</body>
</html>
